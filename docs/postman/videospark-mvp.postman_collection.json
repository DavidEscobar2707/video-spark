          "raw": "{\n  \"workflow\": \"script-to-video\",\n  \"source\": {\n    \"text\": \"Create a short ad for a creative studio. Hook the viewer in the first sentence, explain the offer clearly, and end with a strong call to action.\",\n    \"stylePrompt\": \"Cinematic editorial, clean product ad, premium lighting, modern social media style.\",\n    \"durationSeconds\": 20\n  },\n  \"media\": {\n    \"type\": \"ai-video\",\n    \"quality\": \"pro\",\n    \"density\": \"medium\"\n  },\n  \"voice\": {\n    \"enabled\": true,\n    \"language\": \"en\",\n    \"stability\": 0.4\n  },\n  \"captions\": {\n    \"enabled\": true,\n    \"preset\": \"karaoke\",\n    \"position\": \"bottom\"\n  },\n  \"render\": {\n    \"resolution\": \"720p\"\n  },\n  \"options\": {\n    \"promptTargetDuration\": 20\n  },\n  \"aspectRatio\": \"9:16\"\n}"
